pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/vasukumgit/module-2.git'
            }
        }

        stage('Backend Install') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Deploy Frontend') {
            steps {
                sh 'sudo cp -r frontend/dist/* /var/www/html/'
            }
        }

        stage('Restart Backend') {
            steps {
                dir('backend') {
                    sh 'pm2 restart backend || pm2 start server.js --name backend'
                }
            }
        }
    }
}
